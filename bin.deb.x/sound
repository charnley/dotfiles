#!/usr/bin/env python3

"""

bindsym Control+Up           exec amixer -q sset Master 2%+ unmute
bindsym Control+Down         exec amixer -q sset Master 2%- unmute
bindsym XF86AudioRaiseVolume exec amixer -q set Master 2dB+ unmute
bindsym XF86AudioLowerVolume exec amixer -q set Master 2dB- unmute
bindsym XF86AudioMute exec amixer -q set Master toggle; exec amixer -q set Headphone unmute; exec amixer -q set Speaker unmute # does not work proberbly

"""

from subprocess import PIPE, Popen


# Sinks matching any of these substrings are silently ignored (e.g. microphones)
SINK_IGNORE = ["RODE_NT-USB", "R__DE", "VideoMic"]

# Ordered highest to lowest priority. First matched label wins.
SINK_PRIORITY = [
    {"label": "bluetooth", "match": ["blue"],    "default_volume": 36},
    {"label": "dock",      "match": ["C-Media"], "default_volume": 40},
    {"label": "laptop",    "match": ["pci"],     "default_volume": 50},
]


def shell(cmd):

    cmd = cmd.split()
    p = Popen(cmd, stdin=PIPE, stdout=PIPE, stderr=PIPE)

    stdout, stderr = p.communicate()

    if stderr:
        print(f"err: {stderr}")

    return stdout.decode("utf-8", errors="replace")


def classify_sink(name):
    """Return the priority label for a sink name, or None if it should be ignored."""
    for pattern in SINK_IGNORE:
        if pattern in name:
            return None
    for entry in SINK_PRIORITY:
        for pattern in entry["match"]:
            if pattern in name:
                return entry["label"]
    return "unknown"


def parse_sinks(raw):
    sinks = []
    for line in raw.strip().splitlines():
        parts = line.split()
        if len(parts) < 2:
            continue
        if not parts[0].isdigit():
            continue
        sinks.append({"id": parts[0], "name": parts[1]})
    return sinks


def parse_pactl_info(raw):
    info = {}
    for line in raw.strip().splitlines():
        if ": " in line:
            key, _, value = line.partition(": ")
            info[key.strip()] = value.strip()
    return info


if __name__ == "__main__":

    import argparse

    parser = argparse.ArgumentParser()
    parser.add_argument("-l", "--list", action="store_true", help="List sinks and cards")
    parser.add_argument("change", nargs="?", help="Change volume", default="")
    args = parser.parse_args()

    sinks = parse_sinks(shell("pactl list short sinks"))
    cards = parse_sinks(shell("pactl list cards short"))
    pactl = parse_pactl_info(shell("pactl info"))

    if args.list or not args.change:
        print("Usage: sound <volume%>")
        print()
        for key, value in pactl.items():
            if "Sink" in key:
                print(f"{key}: {value}")
        print()
        print(f"found {len(sinks)} sinks:")
        for sink in sinks:
            label = classify_sink(sink["name"])
            tag = f"[{label}]" if label else "[ignored]"
            print(f"  {sink['id']:>4}  {tag:<12}  {sink['name']}")
        print()
        print(f"found {len(cards)} cards:")
        for card in cards:
            print(f"  {card['id']:>4}  {card['name']}")
        quit()

    # Classify all sinks
    classified = {}  # label -> first matching sink
    for sink in sinks:
        label = classify_sink(sink["name"])
        if label is None:
            continue  # ignored
        if label == "unknown":
            print(f"warning: unrecognized sink {sink['name']}")
            continue
        if label not in classified:
            classified[label] = sink

    # Pick highest-priority available sink
    chosen = None
    chosen_entry: dict | None = None
    for entry in SINK_PRIORITY:
        label = entry["label"]
        if label in classified:
            chosen = classified[label]
            chosen_entry = entry
            break

    if chosen is None:
        print("error: no usable sink found")
        quit(1)

    change = args.change
    if change == "mute":
        change = "0"

    assert chosen_entry is not None

    # Switch default sink if needed, and apply safe default volume on first switch
    if pactl.get("Default Sink") != chosen["name"]:
        shell(f"pactl set-default-sink {chosen['id']}")
        change = str(chosen_entry["default_volume"])

    # Set volume on chosen sink, mute all others
    shell(f"pactl set-sink-volume {chosen['id']} {change}%")
    for sink in sinks:
        if sink["id"] != chosen["id"]:
            shell(f"pactl set-sink-volume {sink['id']} 0%")
