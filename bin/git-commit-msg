#!/usr/bin/env bash
# git-commit-msg — generate a short commit message from a diff using opencode
#
# Usage:
#   git diff --staged | git-commit-msg          # from staged changes
#   git diff          | git-commit-msg          # from unstaged changes
#   git diff HEAD~1   | git-commit-msg          # from last commit
#
# Example workflow:
#   git commit -m "$(git diff --staged | git-commit-msg)"

set -euo pipefail

# ── guards ────────────────────────────────────────────────────────────────────

if ! command -v opencode >/dev/null 2>&1; then
    exit 0
fi

if ! command -v python3 >/dev/null 2>&1; then
    exit 0
fi

# ── read diff from stdin ──────────────────────────────────────────────────────

diff_content=$(cat)

if [[ -z "$diff_content" ]]; then
    >&2 echo "git-commit-msg: no diff on stdin — pipe a diff first"
    >&2 echo "  e.g. git diff --staged | git-commit-msg"
    exit 1
fi

# ── build prompt ──────────────────────────────────────────────────────────────

prompt="Write a short, plain-English git commit message for the following diff.
Rules:
- One line only, no punctuation at the end
- Start with a lowercase verb (add, fix, update, remove, refactor, etc.)
- Be specific but concise (max ~72 chars)
- Output ONLY the commit message, nothing else

Diff:
${diff_content}"

# ── call opencode and extract text ───────────────────────────────────────────

echo $prompt

# opencode run "$prompt" --format json 

